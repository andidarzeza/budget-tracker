# Copy to `.env` next to docker-compose.yml (required for `env_file` on backend).
# CORS is open to any origin in the backend; no CORS_* variables required.

# Mongo URI is set in docker-compose.yml for the `backend` service. To use another DB,
# edit that line or add a docker-compose.override.yml — do not put SPRING_DATA_MONGODB_URI=
# in this file (empty values break Spring).

HTTP_PORT=4001
BACKEND_PORT=9000
