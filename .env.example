# Copy to `.env` next to docker-compose.yml (required for `env_file` on backend).

# SPA origin(s) the browser uses — must match scheme + host + port (no trailing slash).
# Spring maps this to `cors_origin` for CORS when the SPA is on :4001 and the API on :9000.
CORS_ORIGIN=http://YOUR_PUBLIC_IP_OR_DOMAIN:4001

# Optional: override Mongo URI (default uses Docker service `mongo` + timeouts)
# SPRING_DATA_MONGODB_URI=mongodb://mongo:27017/inventar?connectTimeoutMS=10000&serverSelectionTimeoutMS=10000&socketTimeoutMS=30000

HTTP_PORT=4001
BACKEND_PORT=9000
