# Mongo connection used by Spring Boot (default matches docker-compose service name `mongo`)
SPRING_DATA_MONGODB_URI=mongodb://mongo:27017/inventar

# Host port for nginx: Angular app + /api/* proxied to the backend (default matches ng serve)
HTTP_PORT=4001

# Host port for Spring Boot (direct REST access, e.g. other services on the same VPS)
BACKEND_PORT=9000

# Required for Docker: SPA on HTTP_PORT, API on BACKEND_PORT (browser is cross-origin).
# Use your real URL(s), e.g. http://31.97.79.96:4001 or https://app.example.com
# CORS_ORIGIN=http://YOUR_IP:4001
CORS_ORIGIN=
